rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // gizli lig davet kodu: istemci OKUYAMAZ/YAZAMAZ; sadece kurallar get() ile dogrular
    match /config/league {
      allow read, write: if false;
    }

    // uyelik: yalnizca enterLeague fonksiyonu (admin) yazar. Istemci yazamaz.
    match /members/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // herkese acik (uyeye) okunur veriler: devre arasi skorlari vb. Sadece fonksiyon yazar.
    match /public/{doc} {
      allow read: if request.auth != null && exists(/databases/$(database)/documents/members/$(request.auth.uid));
      allow write: if false;
    }

    match /users/{uid} {
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/members/$(request.auth.uid));
      allow create, update: if request.auth != null && request.auth.uid == uid
        && exists(/databases/$(database)/documents/members/$(uid))
        && (!('name' in request.resource.data) ||
            (request.resource.data.name is string &&
             request.resource.data.name.size() >= 2 &&
             request.resource.data.name.size() <= 20))
        && (!('fcmTokens' in request.resource.data) || request.resource.data.fcmTokens is list)
        && (!('favs' in request.resource.data) || request.resource.data.favs is list);

      match /preds/{matchId} {
        allow read: if request.auth != null
          && exists(/databases/$(database)/documents/members/$(request.auth.uid));
        allow create, update: if request.auth != null && request.auth.uid == uid
          && exists(/databases/$(database)/documents/members/$(uid))
          && request.resource.data.h is int && request.resource.data.h >= 0 && request.resource.data.h <= 20
          && request.resource.data.a is int && request.resource.data.a >= 0 && request.resource.data.a <= 20
          && request.resource.data.t == request.time;
      }

      match /picks/{key} {
        allow read: if request.auth != null
          && exists(/databases/$(database)/documents/members/$(request.auth.uid));
        allow create, update: if request.auth != null && request.auth.uid == uid
          && exists(/databases/$(database)/documents/members/$(uid))
          && request.resource.data.t == request.time;
      }
    }

    // liderlik tablosu: collection-group okumalari (uye olmak sart)
    match /{path=**}/preds/{matchId} {
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/members/$(request.auth.uid));
    }
    match /{path=**}/picks/{key} {
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/members/$(request.auth.uid));
    }
  }
}
