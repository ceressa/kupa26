rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == uid
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 20;
      match /preds/{matchId} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null && request.auth.uid == uid
          && request.resource.data.h is int && request.resource.data.h >= 0 && request.resource.data.h <= 20
          && request.resource.data.a is int && request.resource.data.a >= 0 && request.resource.data.a <= 20
          && request.resource.data.t == request.time;
      }
      // turnuva tahminleri: grup cikanlari (group-A..group-L) ve sampiyon (champion)
      match /picks/{key} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null && request.auth.uid == uid
          && request.resource.data.t == request.time;
      }
    }
    // liderlik tablosu: tum tahminleri tek collection-group sorgusuyla okuma izni
    match /{path=**}/preds/{matchId} {
      allow read: if request.auth != null;
    }
    match /{path=**}/picks/{key} {
      allow read: if request.auth != null;
    }
  }
}
